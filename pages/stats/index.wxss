.container {
  position: relative;
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(160deg, var(--theme-field, #f5fbf4) 0%, #f8fbf8 44%, var(--theme-soft, #e7f8e9) 100%);
  overflow: hidden;
}

.container::before,
.container::after {
  content: '';
  position: fixed;
  z-index: 0;
  pointer-events: none;
  filter: blur(36rpx);
  -webkit-filter: blur(36rpx);
}

.container::before {
  left: -120rpx;
  right: -120rpx;
  top: -80rpx;
  height: 420rpx;
  background: linear-gradient(135deg, var(--theme-soft, #e7f8e9) 0%, rgba(255, 255, 255, 0) 72%);
  opacity: 0.82;
}

.container::after {
  left: -120rpx;
  right: -120rpx;
  bottom: -110rpx;
  height: 520rpx;
  background: linear-gradient(25deg, var(--theme-secondary, #8acb45) 0%, rgba(255, 255, 255, 0) 66%);
  opacity: 0.16;
}

.card {
  position: relative;
  z-index: 1;
  background: var(--theme-surface, #ffffff);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 14rpx 34rpx var(--theme-shadow-soft, rgba(0, 0, 0, 0.05));
  border: 2rpx solid var(--theme-border, rgba(93, 150, 91, 0.1));
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: var(--theme-title, #111111);
}

.metric-grid {
  display: flex;
  gap: 16rpx;
}

.metric-item {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.metric-ring {
  width: 170rpx;
  height: 170rpx;
  border-radius: 999rpx;
  padding: 18rpx;
  margin: 0 auto 22rpx;
  box-sizing: border-box;
  box-shadow: inset 0 0 18rpx rgba(255, 255, 255, 0.76);
}

.metric-ring-inner {
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(31, 41, 55, 0.04);
}

.metric-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--theme-primary, #111111);
  line-height: 1.1;
}

.metric-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--theme-muted, #666666);
  line-height: 1.2;
}

.metric-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--theme-title, #111111);
  margin-bottom: 8rpx;
}

.metric-desc {
  font-size: 22rpx;
  color: var(--theme-muted, #666666);
  line-height: 1.45;
}

.weekly-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.weekly-item {
  flex: 0 0 calc(50% - 6rpx);
  min-width: 0;
  border-radius: 16rpx;
  padding: 16rpx 18rpx;
  background: var(--theme-field, #f5fbf4);
  border: 2rpx solid var(--theme-border, rgba(93, 150, 91, 0.1));
}

.weekly-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--theme-title, #111111);
  line-height: 1.2;
}

.weekly-unit {
  margin-left: 4rpx;
  font-size: 20rpx;
  color: var(--theme-muted, #666666);
  font-weight: 500;
}

.weekly-label {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: var(--theme-muted, #666666);
}

.waste-card {
  background: linear-gradient(135deg, #ffffff 0%, var(--theme-field, #f5fbf4) 100%);
}

.waste-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.waste-rate {
  font-size: 52rpx;
  font-weight: 700;
  color: #d96237;
  line-height: 1.1;
}

.waste-label {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: var(--theme-muted, #666666);
}

.waste-copy {
  flex: 1;
  min-width: 0;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.72);
  color: var(--theme-muted, #666666);
  font-size: 25rpx;
  line-height: 1.45;
  text-align: right;
}

.trend-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 76rpx;
  border-bottom: 2rpx solid var(--theme-border, rgba(93, 150, 91, 0.1));
}

.trend-row:last-child {
  border-bottom: none;
}

.trend-label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--theme-title, #111111);
}

.trend-value {
  min-width: 126rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
}

.trend-positive {
  background: #e8f6ec;
  color: #2f8f53;
}

.trend-negative {
  background: #fff0e8;
  color: #d96237;
}

.trend-neutral {
  background: #f1f3f4;
  color: #6f7f72;
}

.muted,
.subtitle {
  color: var(--theme-muted, #666666);
}

.note-line {
  font-size: 26rpx;
  color: var(--theme-muted, #666666);
  line-height: 1.7;
}
