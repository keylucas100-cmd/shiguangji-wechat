.container {
  padding:  28rpx;
}

.card {
  background: var(--theme-surface, #fffefa);
  border-radius: 28rpx;
  padding: 0;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx var(--theme-shadow, rgba(33, 83, 48, 0.12));
}

.entry-header {
  padding: 30rpx 30rpx 26rpx;
  background: linear-gradient(135deg, var(--theme-soft, #e7f8e9) 0%, var(--theme-warm, #fff4cf) 100%);
  border-bottom: 2rpx solid var(--theme-border, rgba(93, 150, 91, 0.14));
}

.entry-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--theme-title, #173d23);
}



.entry-body {
  padding: 28rpx;
}

.form-item {
  margin-bottom: 22rpx;
}

.label {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
  color: var(--theme-title, #304f37);
}

.input,
.picker {
  width: 100%;
  background: var(--theme-field, #f5fbf4);
  border: 2rpx solid var(--theme-border, #dfeee1);
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  min-height: 80rpx;
  box-sizing: border-box;
  color: var(--theme-title, #17251b);
  font-size: 28rpx;
}

.picker-placeholder {
  color: #99a79b !important;
}

.placeholder {
  color: #99a79b;
}

.picker-with-icon {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.picker-icon {
  width: 34rpx;
  height: 34rpx;
  flex: none;
}

.row {
  display: flex;
  align-items: flex-start;
}

.flex-item {
  flex: 1;
}
.field-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.field-main {
  flex: 1;
  min-width: 0;
}

.field-control {
  position: relative;
}

.field-control.has-clear .input,
.field-control.has-clear .picker {
  padding-right: 94rpx;
}

.clear-btn {
  position: absolute;
  right: 20rpx;
  top: 50%;
  z-index: 2;
  transform: translateY(-50%);
  padding: 0;
  background: transparent;
  color: var(--theme-primary, #4f7157);
  font-size: 24rpx;
  line-height: 1;
  text-align: center;
}

.voice-btn {
  flex: 0 0 auto;
  min-height: 80rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, var(--theme-primary, #2fb66d) 0%, var(--theme-secondary, #8acb45) 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
}

.voice-icon {
  width: 45rpx;
  height: 45rpx;
  flex: none;
}

.gap {
  width: 16rpx;
}

.compact-item {
  margin-bottom: 0;
}

.mini-label {
  margin-bottom: 10rpx;
  font-size: 22rpx;
  color: var(--theme-muted, #6f835e);
}

.rule-card {
  min-height: 80rpx;
  height: 80rpx;
  box-sizing: border-box;
  padding: 0 18rpx;
  border: 2rpx solid var(--theme-border, #dfeee1);
  border-radius: 16rpx;
  background: var(--theme-field, #f5fbf4);
  color: var(--theme-title, #17251b);
  display: flex;
  align-items: center;
  justify-content: flex-start;
  text-align: left;
}

.rule-card.is-ready {
  background: var(--theme-field, #f5fbf4);
  color: var(--theme-title, #17251b);
}

.rule-card-value {
  width: 100%;
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.2;
  color: var(--theme-title, #17251b);
  text-align: left;
}

.rule-card-placeholder {
  width: 100%;
  font-size: 28rpx;
  line-height: 1.2;
  color: #99a79b;
  text-align: left;
}

.rule-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 25;
  background: rgba(28, 58, 38, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.rule-modal {
  width: 100%;
  box-sizing: border-box;
  background: var(--theme-surface, #fffefa);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 20rpx 60rpx var(--theme-shadow, rgba(33, 83, 48, 0.18));
}

.rule-modal-title {
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--theme-title, #173d23);
}

.rule-modal-row {
  display: flex;
  align-items: flex-start;
}

.rule-modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.rule-modal-btn {
  flex: 1;
  min-height: 80rpx;
  border-radius: 16rpx;
  text-align: center;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.rule-modal-btn.secondary {
  background: var(--theme-field, #eef6ee);
  color: var(--theme-primary, #4f7157);
  border: 2rpx solid var(--theme-border, #d9eadb);
}

.rule-modal-btn.primary {
  background: linear-gradient(135deg, var(--theme-primary, #2fb66d) 0%, var(--theme-secondary, #8acb45) 100%);
  color: #ffffff;
}

.tag-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.tag {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f0f1f5;
  color: #333333;
  font-size: 24rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #666666;
  margin-top: 8rpx;
}

.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.btn {
  flex: 1;
  border-radius: 16rpx;
  padding: 0;
  min-height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  margin: 0;
}

.clear-form-btn {
  background: var(--theme-field, #eef6ee);
  color: var(--theme-primary, #4f7157);
  border: 2rpx solid var(--theme-border, #d9eadb);
  box-shadow: none;
}

.save-form-btn {
  background: linear-gradient(135deg, var(--theme-primary, #2fb66d) 0%, var(--theme-secondary, #8acb45) 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx var(--theme-shadow, rgba(47, 182, 109, 0.26));
}

.btn::after {
  border: none;
}

.clear-toast {
  position: fixed;
  left: 50%;
  top: 50%;
  z-index: 30;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 26rpx;
  border-radius: 16rpx;
  background: var(--theme-soft, #eaf8ec);
  border: 2rpx solid var(--theme-border, #cfead3);
  box-shadow: 0 12rpx 32rpx var(--theme-shadow, rgba(33, 83, 48, 0.16));
  color: var(--theme-title, #173d23);
  font-size: 26rpx;
  font-weight: 700;
  animation: clearToastPop 1500ms ease both;
}

.clear-toast-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: var(--theme-primary, #2fb66d);
  flex: none;
}

.clear-toast-text {
  white-space: nowrap;
}

@keyframes clearToastPop {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.86);
  }

  12% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  82% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.96);
  }
}

.voice-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(28, 58, 38, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
  animation: voiceMaskFadeIn 180ms ease-out both;
}

.voice-panel {
  width: 100%;
  box-sizing: border-box;
  background: var(--theme-surface, #fffefa);
  border-radius: 28rpx;
  padding: 30rpx 28rpx 28rpx;
  box-shadow: 0 20rpx 60rpx var(--theme-shadow, rgba(33, 83, 48, 0.18));
  animation: voicePanelPopIn 260ms cubic-bezier(0.18, 0.9, 0.24, 1) both;
}

.voice-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--theme-title, #173d23);
}

.voice-desc,
.voice-example {
  font-size: 24rpx;
  color: var(--theme-muted, #6f835e);
  line-height: 1.5;
  margin-top: 12rpx;
}

.voice-textarea {
  width: 100%;
  min-height: 180rpx;
  box-sizing: border-box;
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border: 2rpx solid var(--theme-border, #dfeee1);
  border-radius: 16rpx;
  background: var(--theme-field, #f5fbf4);
  font-size: 28rpx;
  color: var(--theme-title, #17251b);
  line-height: 1.5;
}

.voice-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.voice-action {
  flex: 1;
  min-height: 84rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  line-height: 84rpx;
}

.voice-action.secondary {
  background: var(--theme-field, #eef6ee);
  color: var(--theme-primary, #4f7157);
  border: 2rpx solid var(--theme-border, #d9eadb);
}

.voice-action.primary {
  background: linear-gradient(135deg, var(--theme-primary, #2fb66d) 0%, var(--theme-secondary, #8acb45) 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx var(--theme-shadow, rgba(47, 182, 109, 0.26));
}

@keyframes voiceMaskFadeIn {
  0% {
    opacity: 0;
  }

  100% {
    opacity: 1;
  }
}

@keyframes voicePanelPopIn {
  0% {
    opacity: 0;
    transform: scale(0.86);
  }

  70% {
    opacity: 1;
    transform: scale(1.015);
  }

  100% {
    opacity: 1;
    transform: scale(1);
  }
}
