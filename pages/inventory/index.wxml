<view class="container theme-{{themeKey}}">
  <view class="card">
    <view class="filter-row">
      <block wx:for="{{filterOptions}}" wx:key="key" wx:for-item="filterItem">
        <view
          class="filter-tag status-{{filterItem.key}} {{filter===filterItem.key ? 'active' : ''}}"
          bindtap="setFilter"
          data-filter="{{filterItem.key}}"
        >
          {{filterItem.text}}
        </view>
      </block>
    </view>
  </view>

  <block wx:if="{{list.length}}">
    <block wx:for="{{list}}" wx:key="id">
      <view class="inventory-swipe">
        <view
          class="inventory-delete-action {{openedItemId===item.id ? 'is-visible' : ''}}"
          catchtap="deleteSwipedItem"
          data-id="{{item.id}}"
        >删除</view>
        <view
          class="list-item category-bg-{{item.categoryTheme}} {{animatingItemId===item.id ? 'card-pressing' : ''}} {{openedItemId===item.id ? 'is-open' : ''}}"
          bindtap="editItem"
          bindtouchstart="onItemTouchStart"
          bindtouchend="onItemTouchEnd"
          data-id="{{item.id}}"
        >
          <view class="category-accent"></view>
          <image wx:if="{{item.categoryImage}}" class="category-bg-image" src="{{item.categoryImage}}" mode="aspectFill" />
          <image wx:if="{{item.categoryImage}}" class="category-bg-image blur-layer" src="{{item.categoryImage}}" mode="aspectFill" />
          <view class="item-main">
            <view class="item-content">
              <view class="item-top">
                <view class="title">{{item.name}}</view>
                <view class="quantity">{{item.quantity}}{{item.unit}}</view>
                <view class="tag status-{{item.displayStatus}}">{{item.statusText}}</view>
              </view>
              <view class="item-bottom">
                <view class="expire-line">到期日：{{item.expireDate || '未填写'}}</view>
                <view class="more-btn" catchtap="showItemActions" data-id="{{item.id}}">...</view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </block>
  <view wx:else class="empty">暂无库存记录</view>

  <view wx:if="{{editVisible}}" class="modal-mask">
    <view class="edit-panel">
      <view class="edit-header">
        <view class="modal-title">编辑食材</view>
        <view class="modal-subtitle">整理一下，别让食材被忘记</view>
      </view>

      <view class="edit-body">
        <view class="edit-row">
          <view class="form-item edit-flex">
            <view class="label">食材名称</view>
            <input class="input" value="{{editForm.name}}" data-field="name" bindinput="onEditInput" placeholder="请输入食材名称" />
          </view>
          <view class="edit-gap"></view>
          <view class="form-item edit-flex">
            <view class="label">分类</view>
            <picker range="{{categories}}" value="{{editCategoryIndex}}" bindchange="onEditCategoryChange">
              <view wx:if="{{editForm.category}}" class="picker">{{editForm.category}}</view>
              <view wx:else class="picker picker-placeholder">请选择分类</view>
            </picker>
          </view>
        </view>

        <view class="edit-row">
          <view class="form-item edit-flex">
            <view class="label">数量</view>
            <input class="input" type="number" value="{{editForm.quantity}}" data-field="quantity" bindinput="onEditInput" placeholder="数量" />
          </view>
          <view class="edit-gap"></view>
          <view class="form-item edit-flex">
            <view class="label">单位</view>
            <picker range="{{units}}" value="{{editUnitIndex}}" bindchange="onEditUnitChange">
              <view wx:if="{{editForm.unit}}" class="picker">{{editForm.unit}}</view>
              <view wx:else class="picker picker-placeholder">单位</view>
            </picker>
          </view>
        </view>

        <view class="form-item">
          <view class="label">购买日期（选填）</view>
          <picker mode="date" value="{{editForm.purchaseDate}}" end="{{today}}" bindchange="onEditPurchaseDateChange">
            <view wx:if="{{editForm.purchaseDate}}" class="picker">{{editForm.purchaseDate}}</view>
            <view wx:else class="picker picker-placeholder">请选择购买日期</view>
          </picker>
        </view>

        <view class="form-item">
          <view class="label">出厂日期（选填）</view>
          <picker mode="date" value="{{editForm.productionDate}}" bindchange="onEditProductionDateChange">
            <view wx:if="{{editForm.productionDate}}" class="picker">{{editForm.productionDate}}</view>
            <view wx:else class="picker picker-placeholder">请选择出厂日期</view>
          </picker>
        </view>

        <view class="form-item">
          <view class="label">保质期（选填）</view>
          <input class="input" type="number" value="{{editForm.shelfLifeDays}}" data-field="shelfLifeDays" bindinput="onEditInput" placeholder="请输入保质期天数" />
        </view>

        <view class="form-item">
          <view class="label">预警规则（可修改）</view>
          <view class="rule-card {{editForm.category ? 'is-ready' : ''}}" bindtap="openEditWarningRuleModal">
            <view wx:if="{{editForm.category}}">
              <view class="rule-card-value">{{editForm.lowRiskDays}} / {{editForm.mediumRiskDays}} / {{editForm.highRiskDays}}</view>
            </view>
            <view wx:else class="rule-card-placeholder">选分类后自动带出</view>
          </view>
        </view>

        <view class="form-item">
          <view class="label">预计到期日期</view>
          <picker mode="date" value="{{editForm.expireDate}}" bindchange="onEditExpireDateChange">
            <view wx:if="{{editForm.expireDate}}" class="picker">{{editForm.expireDate}}</view>
            <view wx:else class="picker picker-placeholder">可直接选择预计到期日期</view>
          </picker>
          <view class="picker-hint">填了出厂日期和保质期后，会自动计算到期日期</view>
        </view>

        <view class="modal-actions">
          <view class="modal-btn secondary" bindtap="closeEdit">取消</view>
          <view class="modal-btn primary" bindtap="saveEdit">保存修改</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{editWarningRuleModalVisible}}" class="rule-modal-mask">
    <view class="rule-modal">
      <view class="rule-modal-title">默认规则</view>
      <view class="edit-row">
        <view class="form-item edit-flex">
          <view class="mini-label">低风险阈值</view>
          <input class="input" type="number" value="{{editWarningRuleDraft.lowRiskDays}}" data-field="lowRiskDays" bindinput="onEditWarningRuleDraftInput" placeholder="低风险" />
        </view>
        <view class="edit-gap"></view>
        <view class="form-item edit-flex">
          <view class="mini-label">中风险阈值</view>
          <input class="input" type="number" value="{{editWarningRuleDraft.mediumRiskDays}}" data-field="mediumRiskDays" bindinput="onEditWarningRuleDraftInput" placeholder="中风险" />
        </view>
        <view class="edit-gap"></view>
        <view class="form-item edit-flex">
          <view class="mini-label">高风险阈值</view>
          <input class="input" type="number" value="{{editWarningRuleDraft.highRiskDays}}" data-field="highRiskDays" bindinput="onEditWarningRuleDraftInput" placeholder="高风险" />
        </view>
      </view>
      <view class="rule-modal-actions">
        <view class="rule-modal-btn secondary" bindtap="closeEditWarningRuleModal">取消</view>
        <view class="rule-modal-btn primary" bindtap="confirmEditWarningRuleModal">确定</view>
      </view>
    </view>
  </view>
</view>
